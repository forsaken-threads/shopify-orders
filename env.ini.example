; Shopify Orders — Environment Configuration
; ─────────────────────────────────────────────────────────────────────────────
; Copy this file to env.ini and fill in your values.
; env.ini is listed in .gitignore and must NEVER be committed to source control.
;
; Values set as real environment variables always take precedence over entries
; in this file.
; ─────────────────────────────────────────────────────────────────────────────

; ── Environment name ──────────────────────────────────────────────────────────
; When set to anything other than "production" the value is shown, upper-cased
; and bolded, centered in the header bar — useful for staging/dev deployments.
APP_ENV                 = production

; ── Webhook authentication ────────────────────────────────────────────────────
; Shopify signs every webhook delivery with HMAC-SHA256 using this secret.
; Found in Shopify admin under Settings → Notifications → Webhooks.
SHOPIFY_WEBHOOK_SECRET  = your-shopify-webhook-secret

; ── Initial user seed ─────────────────────────────────────────────────────────
; Read once by scripts/migrate.php to seed the first row in the users table
; (named "Anjela Freeman").  After that initial seed, auth is database-backed
; and these values are ignored.  Use scripts/add-user.php to add further users.
AUTH_USER               = admin
AUTH_PASSWORD           = replace-with-a-strong-password

; ── Shopify Admin API credentials ─────────────────────────────────────────────
; Used to call the Admin API (e.g. fetching product metafields in webhook.php).
;
; SHOPIFY_API_KEY / SHOPIFY_API_SECRET — from your app in the Shopify Partners
;   dashboard or Shopify admin under Apps → your custom app → API credentials.
; SHOPIFY_SHOP_DOMAIN — your store's myshopify.com domain.
; SHOPIFY_API_VERSION — pinned Admin API version; update deliberately.
;
; The Admin API access token is NOT stored here. Run install.php once after
; setting these values to complete the OAuth flow and generate shopify.ini,
; which holds the token. Re-run install.php whenever you rotate app credentials.
SHOPIFY_API_KEY         = your-shopify-api-key
SHOPIFY_API_SECRET      = your-shopify-api-secret
SHOPIFY_SHOP_DOMAIN     = your-store.myshopify.com
SHOPIFY_API_VERSION     = 2025-01

; ── Storefront password protection ────────────────────────────────────────────
; Password shown on the storefront password page when protection is enabled.
; Used by scripts/toggle-password-protection.php.
SHOPIFY_STOREFRONT_PASSWORD = your-storefront-password

; ── Label printer SSH target ─────────────────────────────────────────────────
; SSH destination (user@host) for print-service invocations from
; public/api/print-order.php.  The remote side is expected to run
; ~/print-service/venv/bin/python3 ~/print-service/print-label.py with the
; label arguments; see that endpoint for exact cmdline.
;
; Leave unset to use the production default (keith@percival.spartang.com).
; For local development, point this at your own machine or the LAN printer host.
PRINT_SSH_TARGET = keith@percival.spartang.com
