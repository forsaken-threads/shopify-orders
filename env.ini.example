; Shopify Orders — Environment Configuration
; ─────────────────────────────────────────────────────────────────────────────
; Copy this file to env.ini and fill in your values.
; env.ini is listed in .gitignore and must NEVER be committed to source control.
;
; Values set as real environment variables always take precedence over entries
; in this file.
; ─────────────────────────────────────────────────────────────────────────────

; ── Webhook authentication ────────────────────────────────────────────────────
; Pre-shared Bearer token sent by the caller in the Authorization header:
;   Authorization: Bearer <token>
; Generate with: openssl rand -hex 32
WEBHOOK_BEARER_TOKEN    = replace-with-a-strong-random-token

; ── Orders / download page — HTTP Basic Auth ──────────────────────────────────
AUTH_USER               = admin
AUTH_PASSWORD           = replace-with-a-strong-password

; ── Shopify API credentials ───────────────────────────────────────────────────
; Required when making outbound calls to the Shopify Admin API.
SHOPIFY_API_KEY         = your-shopify-api-key
SHOPIFY_API_SECRET      = your-shopify-api-secret
SHOPIFY_ACCESS_TOKEN    = your-admin-api-access-token
SHOPIFY_SHOP_DOMAIN     = your-store.myshopify.com
