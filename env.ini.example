; Shopify Orders — Environment Configuration
; ─────────────────────────────────────────────────────────────────────────────
; Copy this file to env.ini and fill in your values.
; env.ini is listed in .gitignore and must NEVER be committed to source control.
;
; Values set as real environment variables always take precedence over entries
; in this file.
; ─────────────────────────────────────────────────────────────────────────────

; ── Webhook authentication ────────────────────────────────────────────────────
; Shopify signs every webhook delivery with HMAC-SHA256 using this secret.
; Found in Shopify admin under Settings → Notifications → Webhooks.
SHOPIFY_WEBHOOK_SECRET  = your-shopify-webhook-secret

; ── Orders / download page — HTTP Basic Auth ──────────────────────────────────
AUTH_USER               = admin
AUTH_PASSWORD           = replace-with-a-strong-password

; ── Shopify API credentials ───────────────────────────────────────────────────
; Required when making outbound calls to the Shopify Admin API.
; SHOPIFY_ACCESS_TOKEN — Admin API access token for your private/custom app.
;   Found in Shopify admin under Apps → your app → API credentials.
;   The token must have read_products scope so webhook.php can fetch metafields.
; SHOPIFY_SHOP_DOMAIN  — Your store domain, e.g. your-store.myshopify.com.
; SHOPIFY_API_VERSION  — Pinned Shopify API version used for all Admin API calls.
;   Update this value deliberately; test after each upgrade.
SHOPIFY_API_KEY         = your-shopify-api-key
SHOPIFY_API_SECRET      = your-shopify-api-secret
SHOPIFY_ACCESS_TOKEN    = your-admin-api-access-token
SHOPIFY_SHOP_DOMAIN     = your-store.myshopify.com
SHOPIFY_API_VERSION     = 2025-01
