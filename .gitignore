# Local environment configuration — never commit real credentials
env.ini

# Shopify Admin API access token — written by install.php, never commit
shopify.ini

# SQLite database
orders.sqlite
orders.sqlite-wal
orders.sqlite-shm

# Webhook log files (including rotated: *.log-YYYYMMDD and *.log-YYYYMMDD.gz)
logs/*.log
logs/*.log-*

# Composer-managed dependencies. composer.json and composer.lock are committed;
# vendor/ is regenerated via `composer install` (or `./do composer install`).
vendor/
